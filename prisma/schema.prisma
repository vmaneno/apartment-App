generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// The tenant of the software — a management company, or a self-managed owner-operator.
model Organization {
  id            String    @id @default(cuid())
  name          String
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  closedThrough DateTime?

  users           User[]
  owners          Owner[]
  properties      Property[]
  tenants         Tenant[]
  vendors         Vendor[]
  chartOfAccounts ChartOfAccount[]
  budgets         Budget[]
  documents       Document[]
  inspections     Inspection[]
  applicants      Applicant[]
}

// Org staff login (admin/staff) — not a tenant or owner-portal login.
model User {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  email          String       @unique
  userName       String       @unique
  password       String
  role           String       @default("staff") // 'admin' | 'staff'
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
}

// A party who holds equity in one or more Properties. Modeled explicitly even when it's the
// same legal entity as the Organization (self-managed), so reporting never has to special-case it.
model Owner {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  type           String       @default("Individual") // 'Individual' | 'LLC'
  email          String?
  phone          String?
  active         Boolean      @default(true)

  propertyOwners     PropertyOwner[]
  ownerDistributions OwnerDistribution[]
}

model Property {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  addressLine1   String
  addressLine2   String?
  city           String
  state          String
  zip            String
  propertyValue  Float? // for Cap Rate reporting (NOI ÷ Property Value); optional, admin-entered
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())

  propertyOwners      PropertyOwner[]
  managementAgreement ManagementAgreement?
  units               Unit[]
  workOrders          WorkOrder[]
  bankAccounts        BankAccount[]
  transactionLines    TransactionLine[]
  vendorInvoices      VendorInvoice[]
  ownerDistributions  OwnerDistribution[]
  budgets             Budget[]
  documents           Document[]
  inspections         Inspection[]
  applicants          Applicant[]
}

// Join: Property <-> Owner, with ownership % — supports co-owned properties.
model PropertyOwner {
  id               String   @id @default(cuid())
  propertyId       String
  property         Property @relation(fields: [propertyId], references: [id])
  ownerId          String
  owner            Owner    @relation(fields: [ownerId], references: [id])
  ownershipPercent Float    @default(100)

  @@unique([propertyId, ownerId])
}

// Fee terms for a managed (not self-managed) property. Absent or feePercent = 0 for self-managed.
model ManagementAgreement {
  id               String    @id @default(cuid())
  propertyId       String    @unique
  property         Property  @relation(fields: [propertyId], references: [id])
  feePercent       Float     @default(0)
  leasingFeeAmount Float?
  effectiveDate    DateTime  @default(now())
  endDate          DateTime?
}

model Unit {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  unitNumber String
  beds       Int      @default(0)
  baths      Float    @default(0)
  sqft       Int?
  marketRent Float?
  active     Boolean  @default(true)

  leases      Lease[]
  workOrders  WorkOrder[]
  documents   Document[]
  inspections Inspection[]
  applicants  Applicant[]

  @@unique([propertyId, unitNumber])
}

model Tenant {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  email          String?
  phone          String?
  password       String? // bcrypt hash; null means the tenant portal isn't set up for this tenant yet
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())

  leaseTenants LeaseTenant[]
  documents    Document[]
  submittedWorkOrders WorkOrder[]
}

model Lease {
  id            String    @id @default(cuid())
  unitId        String
  unit          Unit      @relation(fields: [unitId], references: [id])
  status        String    @default("Active") // 'Active' | 'Ended' | 'Pending'
  startDate     DateTime
  endDate       DateTime?
  rentAmount    Float
  depositAmount Float     @default(0)
  createdAt     DateTime  @default(now())

  leaseTenants    LeaseTenant[]
  leaseCharges    LeaseCharge[]
  payments        Payment[]
  securityDeposit SecurityDeposit?
  documents       Document[]
}

// Join: Lease <-> Tenant, for co-tenants.
model LeaseTenant {
  id       String @id @default(cuid())
  leaseId  String
  lease    Lease  @relation(fields: [leaseId], references: [id])
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([leaseId, tenantId])
}

model LeaseCharge {
  id         String   @id @default(cuid())
  leaseId    String
  lease      Lease    @relation(fields: [leaseId], references: [id])
  chargeType String   // 'Rent' | 'Pet Rent' | 'Parking' | 'Late Fee' | ...
  amount     Float
  recurring  Boolean  @default(false)
  date       DateTime @default(now())

  paymentApplications PaymentApplication[] @relation("ChargeTx")
}

model Payment {
  id      String   @id @default(cuid())
  leaseId String
  lease   Lease    @relation(fields: [leaseId], references: [id])
  amount  Float
  date    DateTime @default(now())
  method  String   // 'ACH' | 'Card' | 'Check' | 'Cash'

  paymentApplications PaymentApplication[] @relation("PaymentTx")
}

// Links a Payment to the LeaseCharge(s) it pays off — same shape as USHoa-App's PaymentApplication.
model PaymentApplication {
  id            String      @id @default(cuid())
  paymentId     String
  payment       Payment     @relation("PaymentTx", fields: [paymentId], references: [id])
  chargeId      String
  charge        LeaseCharge @relation("ChargeTx", fields: [chargeId], references: [id])
  appliedAmount Float
}

model Vendor {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  trade          String?
  email          String?
  phone          String?
  coiExpiresAt   DateTime?
  w9OnFile       Boolean      @default(false)
  active         Boolean      @default(true)

  workOrders      WorkOrder[]
  vendorInvoices  VendorInvoice[]
  vendorPayments  VendorPayment[]
  documents       Document[]
}

// AP mirror of LeaseCharge — one invoice, one Expense GL line.
model VendorInvoice {
  id            String         @id @default(cuid())
  vendorId      String
  vendor        Vendor         @relation(fields: [vendorId], references: [id])
  propertyId    String
  property      Property       @relation(fields: [propertyId], references: [id])
  glAccountId   String
  glAccount     ChartOfAccount @relation(fields: [glAccountId], references: [id])
  invoiceNumber String?
  amount        Float
  date          DateTime       @default(now())
  description   String?

  paymentApplications VendorPaymentApplication[] @relation("InvoiceTx")
}

// AP mirror of Payment — a vendor payment, FIFO-allocated across their outstanding invoices.
model VendorPayment {
  id            String      @id @default(cuid())
  vendorId      String
  vendor        Vendor      @relation(fields: [vendorId], references: [id])
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  amount        Float
  date          DateTime    @default(now())
  method        String

  paymentApplications VendorPaymentApplication[] @relation("PaymentTx")
}

// Links a VendorPayment to the VendorInvoice(s) it pays off — mirrors PaymentApplication.
model VendorPaymentApplication {
  id            String        @id @default(cuid())
  paymentId     String
  payment       VendorPayment @relation("PaymentTx", fields: [paymentId], references: [id])
  invoiceId     String
  invoice       VendorInvoice @relation("InvoiceTx", fields: [invoiceId], references: [id])
  appliedAmount Float
}

model WorkOrder {
  id               String    @id @default(cuid())
  propertyId       String
  property         Property  @relation(fields: [propertyId], references: [id])
  unitId           String?
  unit             Unit?     @relation(fields: [unitId], references: [id])
  description      String
  priority         String    @default("Routine") // 'Emergency' | 'Routine'
  status           String    @default("Open") // 'Open' | 'Assigned' | 'InProgress' | 'Completed'
  assignedVendorId String?
  assignedVendor   Vendor?   @relation(fields: [assignedVendorId], references: [id])
  submittedByTenantId String?
  submittedByTenant   Tenant? @relation(fields: [submittedByTenantId], references: [id])
  createdAt        DateTime  @default(now())
  completedAt      DateTime?
}

model BankAccount {
  id          String         @id @default(cuid())
  propertyId  String
  property    Property       @relation(fields: [propertyId], references: [id])
  name        String
  type        String         @default("Operating") // 'Operating' | 'SecurityDepositTrust' | 'Reserve'
  glAccountId String
  glAccount   ChartOfAccount @relation(fields: [glAccountId], references: [id])
  active      Boolean        @default(true)

  vendorPayments     VendorPayment[]
  securityDeposits   SecurityDeposit[]
  ownerDistributions OwnerDistribution[]
}

// A cash payout to an Owner for their share of a Property's net income.
model OwnerDistribution {
  id            String      @id @default(cuid())
  ownerId       String
  owner         Owner       @relation(fields: [ownerId], references: [id])
  propertyId    String
  property      Property    @relation(fields: [propertyId], references: [id])
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  amount        Float
  date          DateTime    @default(now())
}

// Deposit lifecycle for a lease: one row, updated on return. Its own model
// rather than reusing Payment/VendorPayment because a deposit's money
// doesn't offset a Charge/Invoice — it just moves between an Asset (trust
// cash) and a Liability.
model SecurityDeposit {
  id               String      @id @default(cuid())
  leaseId          String      @unique
  lease            Lease       @relation(fields: [leaseId], references: [id])
  bankAccountId    String
  bankAccount      BankAccount @relation(fields: [bankAccountId], references: [id])
  amount           Float
  collectedDate    DateTime    @default(now())
  returnedDate     DateTime?
  returnedToTenant Float?
  retained         Float?
}

// Chart of Accounts, scoped per Organization (mirrors USHoa-App's per-HOA COA).
model ChartOfAccount {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  glNumber       String
  glName         String
  glType         String       // 'Asset' | 'Liability' | 'Equity' | 'Income' | 'Expense'
  active         Boolean      @default(true)

  lines          TransactionLine[]
  bankAccounts   BankAccount[]
  vendorInvoices VendorInvoice[]
  budgets        Budget[]

  @@unique([organizationId, glNumber])
}

// Double-entry ledger, same shape as USHoa-App's accounting.ts. organizationId is a plain
// string (not an FK) to match that app's lightweight tenant-scoping convention on ledger tables.
model Transaction {
  id              String   @id @default(cuid())
  organizationId  String
  date            DateTime @default(now())
  transactionType String
  description     String
  memo            String?
  createdAt       DateTime @default(now())

  lines TransactionLine[]
}

// propertyId tags each line the same way USHoa-App tags lines with `fund` — a per-property
// NOI report is just a filter on this field, not a separate ledger.
model TransactionLine {
  id            String         @id @default(cuid())
  transactionId String
  transaction   Transaction    @relation(fields: [transactionId], references: [id])
  glAccountId   String
  glAccount     ChartOfAccount @relation(fields: [glAccountId], references: [id])
  propertyId    String?
  property      Property?      @relation(fields: [propertyId], references: [id])
  debit         Float          @default(0)
  credit        Float          @default(0)
  description   String?
  cleared       Boolean        @default(false)
  clearedAt     DateTime?
}

// One row per property/GL-account/month — the monthly budgeted amount, compared against
// actual TransactionLine activity by the Budget vs. Actual report. Only meaningful for
// Income/Expense glAccounts, but not restricted at the schema level (mirrors how LeaseCharge
// doesn't restrict its glAccount type either).
model Budget {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  propertyId     String
  property       Property       @relation(fields: [propertyId], references: [id])
  glAccountId    String
  glAccount      ChartOfAccount @relation(fields: [glAccountId], references: [id])
  year           Int
  month          Int // 1-12
  amount         Float          @default(0)

  @@unique([propertyId, glAccountId, year, month])
}

// File content lives in the row (`content Bytes`) rather than an object-storage bucket — no
// Supabase Storage credentials are configured for this app yet (only DATABASE_URL/DIRECT_URL),
// and this keeps the feature deployable without new infra. Revisit if files grow large/numerous
// enough that Postgres row storage becomes the bottleneck. Every link field is optional — a
// document can be unattached (general org file) or attached to exactly the entities it's
// relevant to (e.g. a signed lease PDF sets leaseId, a vendor's W-9 sets vendorId).
model Document {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  fileName       String
  mimeType       String
  size           Int
  content        Bytes
  category       String // 'Lease' | 'W9' | 'COI' | 'Inspection' | 'ID' | 'Other'
  propertyId     String?
  property       Property? @relation(fields: [propertyId], references: [id])
  unitId         String?
  unit           Unit?     @relation(fields: [unitId], references: [id])
  leaseId        String?
  lease          Lease?    @relation(fields: [leaseId], references: [id])
  tenantId       String?
  tenant         Tenant?   @relation(fields: [tenantId], references: [id])
  vendorId       String?
  vendor         Vendor?   @relation(fields: [vendorId], references: [id])
  inspectionId   String?
  inspection     Inspection? @relation(fields: [inspectionId], references: [id])
  applicantId    String?
  applicant      Applicant? @relation(fields: [applicantId], references: [id])
  uploadedAt     DateTime  @default(now())
}

// Move-in/move-out condition reports and routine/turn walkthroughs. Deliberately no structured
// checklist/scoring — just header fields + free-text notes + attached Documents (photos), same
// minimal shape as WorkOrder before it grew any richer.
model Inspection {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  propertyId     String
  property       Property     @relation(fields: [propertyId], references: [id])
  unitId         String?
  unit           Unit?        @relation(fields: [unitId], references: [id])
  type           String       @default("Routine") // 'Move-In' | 'Move-Out' | 'Routine' | 'Turn'
  status         String       @default("Scheduled") // 'Scheduled' | 'Completed' | 'Cancelled'
  scheduledDate  DateTime
  completedDate  DateTime?
  inspectorName  String?
  notes          String?
  createdAt      DateTime     @default(now())

  documents Document[]
}

// Prospective-tenant tracking (application → screening → decision). No integration with a
// third-party background-check/credit provider — this app has no credentials for one, so
// `status` and `notes` are set manually by staff, same as every other manual-decision field
// in this codebase (e.g. Vendor.w9OnFile).
model Applicant {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  propertyId      String
  property        Property     @relation(fields: [propertyId], references: [id])
  unitId          String?
  unit            Unit?        @relation(fields: [unitId], references: [id])
  name            String
  email           String?
  phone           String?
  status          String       @default("Applied") // 'Applied' | 'Screening' | 'Approved' | 'Denied' | 'Withdrawn'
  applicationDate DateTime     @default(now())
  notes           String?
  createdAt       DateTime     @default(now())

  documents Document[]
}
